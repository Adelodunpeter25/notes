{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@shared/*": [
        "../shared/types/*"
      ],
      "@shared-utils/*": [
        "../shared/utils/*"
      ],
      "@shared-hooks/*": [
        "../shared/hooks/*"
      ]
    }
  }
}
